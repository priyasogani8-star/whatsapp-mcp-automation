    "type": "change_vote",
    "pollId": "poll_xyz789",
    "userId": "user_1",
    "newSelectedChoices": ["2bhk", "3bhk"],
    "explanation": "User removes 1 BHK from selection. Previous: [1BHK, 2BHK, 3BHK] → New: [2BHK, 3BHK]"
  },

  "expected_result": {
    "pollId": "poll_xyz789",
    "question": "What property types interest you?",
